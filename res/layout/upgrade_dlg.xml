<?xml version="1.0" encoding="utf-8"?>
<TabHost xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@android:id/tabhost"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <TabWidget
            android:id="@android:id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
            
        <FrameLayout
            android:id="@android:id/tabcontent"
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:layout_height="0dp">

            <ScrollView
                android:id="@+id/tab1"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout 
                    android:orientation="vertical" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content"
                    android:padding="10dp">
                    
                    <Button 
                        android:id="@+id/buy_upgrade_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Buy a Phone" />

                    <Button 
                        android:id="@+id/buy_upgrade_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hire Techzasters" />

                    <Button 
                        android:id="@+id/buy_upgrade_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mod a Phone" />
						
					<Button 
                        android:id="@+id/buy_upgrade_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Unbrick a Phone" />
						
					<Button 
                        android:id="@+id/buy_upgrade_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rom Downloader" />
                </LinearLayout>
            </ScrollView>

            <ScrollView
                android:id="@+id/tab2"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout 
                    android:orientation="vertical" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content"
                    android:padding="10dp">
                    <Button 
                        android:id="@+id/buy_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SD Card (cost 2.5k)" />
					<Button 
                        android:id="@+id/buy_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TWRP (cost 10.5k)" />
					<Button 
                        android:id="@+id/buy_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="3000 Roms (cost 125.5k)" />
					<Button 
                        android:id="@+id/buy_item_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fast Internet (cost 2.25M)" />
					<Button 
                        android:id="@+id/buy_item_5"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phone Parts (cost 3.55M)" />
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

        <Button
            android:id="@+id/close_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Game" />

    </LinearLayout>
</TabHost>